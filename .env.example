# ============================================================
#  NewsClip Backend — Environment Variables
#  Salin file ini menjadi .env untuk development lokal
#  Set variabel ini di Vercel Dashboard > Project Settings
# ============================================================

# TiDB Cloud Connection (dapatkan dari TiDB Cloud Console)
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_NAME=newsclip
DB_USER=your_tidb_username.root
DB_PASS=your_tidb_password

# JWT Secret — ganti dengan string acak yang kuat!
# Generator: https://randomkeygen.com/ (pilih 504-bit)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
